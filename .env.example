# Optional overrides (defaults work without any configuration)
# OPEN_METEO_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1
# OPEN_METEO_FORECAST_BASE_URL=https://api.open-meteo.com/v1

# MySQL (Docker Compose sets these for the api service)
# DATABASE_URL=mysql+pymysql://weather:weather@localhost:3306/weather
# DATABASE_ENABLED=true

# Dev-only: create a test user on startup (enabled in docker-compose.yml)
# SEED_TEST_USER=true
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=testpassword
